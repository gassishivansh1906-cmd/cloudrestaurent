# ---- Server ----
PORT=5000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# ---- JWT ----
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ---- SQL Server (SSMS 22) ----
# For a local SQL Server instance managed via SSMS:
#   DB_SERVER=localhost  (or  localhost\SQLEXPRESS  / your instance name)
#   DB_USER + DB_PASSWORD must be a SQL login (enable "SQL Server Authentication")
# For the docker-compose SQL Server container, DB_SERVER=db
DB_SERVER=localhost
DB_PORT=1433
DB_NAME=CloudRestaurant
DB_USER=sa
DB_PASSWORD=YourStrong!Passw0rd
DB_ENCRYPT=false
DB_TRUST_SERVER_CERT=true

# ---- Bootstrap admin (created automatically on first start) ----
ADMIN_NAME=Restaurant Admin
ADMIN_EMAIL=admin@cloud.com
ADMIN_PASSWORD=Admin@123
