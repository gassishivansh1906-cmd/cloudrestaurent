# =====================================================================
# Root environment file for docker-compose.
# Copy this to ".env" (same folder as docker-compose.yml) and adjust.
#   cp .env.example .env
# =====================================================================

# SQL Server SA password (must meet SQL Server complexity rules)
DB_PASSWORD=YourStrong!Passw0rd

# JWT signing secret - change this to a long random string in production
JWT_SECRET=please-change-me-to-a-long-random-secret

# Allowed CORS origin for the API (your public site URL in production)
CLIENT_ORIGIN=http://localhost

# Bootstrap admin account (created automatically on first backend start)
ADMIN_NAME=Restaurant Admin
ADMIN_EMAIL=admin@cloud.com
ADMIN_PASSWORD=Admin@123
