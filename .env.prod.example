# =====================================================================
# PRODUCTION env for docker-compose.prod.yml (EC2 + RDS SQL Server)
# Copy to ".env" on the EC2 instance and fill in your RDS details.
#   cp .env.prod.example .env
# =====================================================================

# ---- Amazon RDS for SQL Server (Express, free tier) ----
DB_SERVER=YOUR-RDS-ENDPOINT.rds.amazonaws.com
DB_PORT=1433
DB_NAME=CloudRestaurant
DB_USER=admin
DB_PASSWORD=YourStrongRdsPassw0rd!

# ---- App secrets ----
JWT_SECRET=please-change-me-to-a-long-random-secret
CLIENT_ORIGIN=http://YOUR-EC2-PUBLIC-IP

# ---- Bootstrap admin (created automatically on first backend start) ----
ADMIN_NAME=Restaurant Admin
ADMIN_EMAIL=admin@cloud.com
ADMIN_PASSWORD=Admin@123
